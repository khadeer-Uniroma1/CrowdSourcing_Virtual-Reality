# Asset Store tools / exported objects
ExportedObj/
*.unitypackage

# Uncomment if using Rider
.idea/

# Keep Unity asset meta files and Assets/ and ProjectSettings/ and Packages/
# (these should be tracked so Unity can resolve GUIDs and project settings)
!/[Aa]ssets/**/.meta
!/[Aa]ssets/**/*.meta
!/[Pp]roject[Ss]ettings/**

# User-specific settings folder (do not track)
/[Uu]ser[Ss]ettings/

# Optional: ignore large media unless you use Git LFS
# *.psd
# *.tga
# *.png
# *.jpg
# *.wav
# *.mp4

# End